{
  "name": "tsutsumi-portfolio-root",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.23.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter tsutsumin-portfolio dev",
    "build": "pnpm --dir tsutsumin-portfolio install --frozen-lockfile && pnpm --dir tsutsumin-portfolio build",
